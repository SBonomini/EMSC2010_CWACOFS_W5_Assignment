          "text": [
            "[[21.7 22.1 32.5 ... 32.6 18.6 23.9]\n",
            " [24.8 32.2 29.  ... 32.6 32.2 31.1]\n",
            " [32.8 26.3 18.6 ... 26.3 26.3 27.3]\n",
            " ...\n",
            " [26.3 31.1 32.8 ... 26.3 21.7 32.5]\n",
            " [21.7 28.9 22.1 ... 18.6 27.8 21.7]\n",
            " [33.3 32.5 24.8 ... 29.8 27.9 29. ]]\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "Ulladulla = np.random.choice(df['ulladulla (ºC)'].dropna(), size=(len(df), 100000), replace=True)\n",
        "#Create 100000 simulated versions of Ulladulla temperature dataset by randomly resampling it (with replacement)\n",
        "#len(X) is the length of Ulladulla data (which is 29), repeat 100000 times\n",
        "print(Ulladulla)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "uhjbipDC269q",
        "outputId": "5bb8dbad-6908-4eda-f916-2d821821790a"
