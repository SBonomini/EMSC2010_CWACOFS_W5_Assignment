          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "bar_Canberra = np.mean(Canberra,axis=0)\n",
        "bar_Ulladulla = np.mean(Ulladulla,axis=0)\n",
        "#Take the average of each column in the Canberra and Ulladulla random choice dataset"
      ],
      "metadata": {
        "id": "WfV-6U7q2-sr"
      },
      "execution_count": null,
